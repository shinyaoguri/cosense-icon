{
  "name": "cosense-icon",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "Shinya Oguri",
  "description": "Cosense用のページアイコンをパスから動的に生成するCloudflare Worker",
  "type": "module",
  "scripts": {
    "build:editor": "node scripts/build-editor.mjs",
    "build:editor:dev": "node scripts/build-editor.mjs --dev",
    "dev": "npm run build:editor:dev && wrangler dev",
    "deploy": "npm run build:editor && wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.editor.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250419.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  }
}
